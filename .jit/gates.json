{
  "gates": {
    "code-review": {
      "version": 1,
      "key": "code-review",
      "title": "AI Code Review",
      "description": "AI-powered code review against just-in-time project standards",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "./scripts/ai-review.sh",
        "timeout_seconds": 1800,
        "working_dir": null,
        "env": {
          "REVIEWER_AGENT": "copilot -s --model gpt-5.4 --allow-tool \"shell(cargo test)\" --allow-tool \"shell(cargo clippy)\" --allow-tool \"shell(cargo fmt)\" --allow-tool \"shell(npm test)\" --allow-tool \"shell(npm run lint)\" --allow-tool \"shell(npm run build)\" --allow-tool \"shell(./scripts/jit-validate.sh)\""
        },
        "pass_context": true,
        "prompt_file": "./scripts/code-review-prompt.md"
      },
      "priority": 100,
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "tests": {
      "version": 1,
      "key": "tests",
      "title": "All Tests Pass",
      "description": "Full test suite must pass",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo test --lib",
        "timeout_seconds": 300,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "priority": 100,
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "npm-ci": {
      "version": 1,
      "key": "npm-ci",
      "title": "NPM CI (test + lint + build)",
      "description": "Web workspace checks: vitest suite, ESLint, and production build all clean. Web-side equivalent of cargo-ci.",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cd web && npm test -- --run && npm run lint && npm run build",
        "timeout_seconds": 600,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "priority": 100,
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "clippy": {
      "version": 1,
      "key": "clippy",
      "title": "Clippy Lints Pass",
      "description": "Zero clippy warnings allowed",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo clippy --lib -- -D warnings",
        "timeout_seconds": 120,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "priority": 100,
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "cargo-ci": {
      "version": 1,
      "key": "cargo-ci",
      "title": "Cargo CI (fmt + clippy + tests)",
      "description": "Full Rust CI pipeline: formatting check, zero-warning clippy, and the workspace test suite must all pass.",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace",
        "timeout_seconds": 900,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "priority": 100,
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "tdd-reminder": {
      "version": 1,
      "key": "tdd-reminder",
      "title": "TDD Reminder",
      "description": "Write tests first",
      "stage": "precheck",
      "mode": "manual",
      "priority": 100,
      "reserved": {},
      "auto": false,
      "example_integration": null
    },
    "fmt": {
      "version": 1,
      "key": "fmt",
      "title": "Code Formatted",
      "description": "Code must be formatted with cargo fmt",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo fmt -- --check",
        "timeout_seconds": 30,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "priority": 100,
      "reserved": {},
      "auto": true,
      "example_integration": null
    }
  }
}