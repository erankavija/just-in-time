{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Bug triage content schema. Requires the projection's parsed body to contain a Reproduction section with at least one list item (a reproduction step).",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "object",
      "required": ["reproduction"],
      "properties": {
        "reproduction": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
